# Copy to .env.local and fill in. All values are server-side only.

# OpenAI - powers the AI Vision extraction path (gpt-4o).
OPENAI_API_KEY=

# ATS Tracker (TrackerRMS) - long-lived bearer token, exchanged server-side
# for a ~7-day JWT. Without it the Tracker push button returns an error;
# extraction and CSV export still work.
TRACKER_API_TOKEN=
# Optional - defaults to the US endpoint.
TRACKER_API_URL=https://evousapi.tracker-rms.com

# Team access gate. When BCX_ACCESS_CODE is set, every page and API route
# requires the code (entered once per device, stored as a signed cookie).
# REQUIRED for any deployment reachable beyond localhost.
BCX_ACCESS_CODE=
# Secret for signing session cookies. Generate with: openssl rand -hex 32
BCX_SESSION_SECRET=
